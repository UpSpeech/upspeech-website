# EmailJS Configuration
# Copy this to .env.local and replace with your actual EmailJS credentials

VITE_EMAILJS_SERVICE_ID=your_emailjs_service_id
VITE_EMAILJS_TEMPLATE_ID=your_emailjs_template_id
VITE_EMAILJS_PUBLIC_KEY=your_emailjs_public_key

# Product Analytics (PostHog)
VITE_POSTHOG_KEY=
VITE_POSTHOG_HOST=https://eu.i.posthog.com

# Backend API base URL. Used by src/lib/api.ts to fetch the techniques content
# that is prerendered into static HTML at build time. If this is unset, the app
# falls back to http://localhost:3050/api/v1, which is correct for local dev
# (run the backend) but FATAL for a production build: the techniques pages will
# render their error state and ship as broken HTML.
#
# Production (Netlify) MUST set this to the production backend, e.g.:
#   VITE_API_URL=https://app-backend-production-f30a.up.railway.app/api/v1
# (this host is already allow-listed in netlify.toml CSP connect-src)
VITE_API_URL=
